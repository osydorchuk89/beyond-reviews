// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum MediaType {
  MOVIE
  BOOK
  ALBUM
}

model User {
  id                     String                      @id @default(auto()) @map("_id") @db.ObjectId
  firstName              String
  lastName               String
  email                  String                      @unique
  password               String?
  photo                  String?
  reviews                Review[]
  likes                  ReviewLike[]
  savedItems             SavedItem[]
  activities             Activity[]
  friends                User[]                      @relation(fields: [friendsIds], references: [id], name: "friends")
  friendsIds             String[]                    @db.ObjectId
  friendOf               User[]                      @relation(fields: [friendOfIds], references: [id], name: "friends")
  friendOfIds            String[]                    @db.ObjectId
  sentFriendRequests     FriendRequest[]             @relation("sentUser")
  receivedFriendRequests FriendRequest[]             @relation("receivedUser")
  sentMessages           Message[]                   @relation("sender")
  receivedMessages       Message[]                   @relation("recipient")
  recommendations        RecommendationCache[]       @relation("recommendationUser")
  friendRecommendations  FriendRecommendationCache[] @relation("friendRecommendationUser")
  recommendedToUsers     FriendRecommendationCache[] @relation("recommendedUser")
}

model MediaItem {
  id              String                @id @default(auto()) @map("_id") @db.ObjectId
  type            MediaType             @default(MOVIE)
  title           String
  releaseYear     Int
  overview        String
  language        String
  genres          String[]
  keywords        String[]              @default([])
  popularity      Float                 @default(0)
  avgRating       Float                 @default(0)
  numRatings      Int                   @default(0)
  image           String                @map("poster")
  movie           Movie?
  book            Book?
  reviews         Review[]
  savedByUsers    SavedItem[]
  userActivities  Activity[]
  recommendations RecommendationCache[]

  @@index([type])
  @@index([type, title])
  @@map("Movie")
}

model Movie {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id])
  mediaItemId String    @unique @db.ObjectId
  tmdbId      Int?
  director    String
  cast        String[]  @default([])
  runtime     Int

  @@index([tmdbId])
  @@map("MovieDetails")
}

model Book {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  mediaItem    MediaItem @relation(fields: [mediaItemId], references: [id])
  mediaItemId  String    @unique @db.ObjectId
  authors      String[]
  pageCount    Int?
  isbn10       String?
  isbn13       String?
  googleBookId String?

  @@index([googleBookId])
  @@index([isbn13])
  @@map("BookDetails")
}

model RecommendationCache {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  user               User      @relation(fields: [userId], references: [id], name: "recommendationUser")
  userId             String    @db.ObjectId
  mediaType          MediaType @default(MOVIE)
  mediaItem          MediaItem @relation(fields: [mediaItemId], references: [id])
  mediaItemId        String    @map("movieId") @db.ObjectId
  score              Float
  recommendedByCount Int
  generatedAt        DateTime

  @@unique([userId, mediaItemId])
  @@index([userId, score])
  @@index([userId, mediaType, score])
  @@map("MovieRecommendationCache")
}

model FriendRecommendationCache {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  user                 User     @relation(fields: [userId], references: [id], name: "friendRecommendationUser")
  userId               String   @db.ObjectId
  recommendedUser      User     @relation(fields: [recommendedUserId], references: [id], name: "recommendedUser")
  recommendedUserId    String   @db.ObjectId
  similarityScore      Float
  sharedMovieCount     Int
  sharedFavoriteTitles String[]
  generatedAt          DateTime

  @@unique([userId, recommendedUserId])
  @@index([userId, similarityScore])
}

model Review {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  mediaItem      MediaItem    @relation(fields: [mediaItemId], references: [id])
  mediaItemId    String       @map("movieId") @db.ObjectId
  mediaType      MediaType    @default(MOVIE)
  user           User         @relation(fields: [userId], references: [id])
  userId         String       @db.ObjectId
  date           DateTime
  rating         Int
  text           String?
  likeCount      Int          @default(0)
  likedBy        ReviewLike[]
  userActivities Activity[]

  @@unique([mediaItemId, userId])
  @@index([userId])
  @@index([userId, mediaType])
  @@index([mediaItemId, likeCount])
  @@index([mediaType, mediaItemId])
  @@map("MovieReview")
}

model ReviewLike {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  review   Review @relation(fields: [reviewId], references: [id])
  reviewId String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id])
  userId   String @db.ObjectId

  @@unique([reviewId, userId])
  @@map("MovieReviewLike")
}

model SavedItem {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  userId      String    @db.ObjectId
  mediaType   MediaType @default(MOVIE)
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id])
  mediaItemId String    @map("movieId") @db.ObjectId

  @@unique([mediaItemId, userId])
  @@index([userId, mediaType])
  @@map("MovieWatchList")
}

model Activity {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  user         User       @relation(fields: [userId], references: [id])
  userId       String     @db.ObjectId
  action       String
  reviewRating Int?
  reviewText   String?
  mediaItem    MediaItem? @relation(fields: [mediaItemId], references: [id])
  mediaItemId  String?    @map("movieId") @db.ObjectId
  review       Review?    @relation(fields: [reviewId], references: [id])
  reviewId     String?    @map("movieReviewId") @db.ObjectId
  date         DateTime

  @@index([mediaItemId])
  @@index([reviewId])
}

model FriendRequest {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  sentUser       User   @relation(fields: [sentUserId], references: [id], name: "sentUser")
  sentUserId     String @db.ObjectId
  receivedUser   User   @relation(fields: [receivedUserId], references: [id], name: "receivedUser")
  receivedUserId String @db.ObjectId

  @@unique([sentUserId, receivedUserId])
}

model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sender      User     @relation(fields: [senderId], references: [id], name: "sender")
  senderId    String   @db.ObjectId
  recipient   User     @relation(fields: [recipientId], references: [id], name: "recipient")
  recipientId String   @db.ObjectId
  text        String
  date        DateTime
  wasRead     Boolean
}
