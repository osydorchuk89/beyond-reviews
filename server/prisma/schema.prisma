// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model User {
    id                     String            @id @default(auto()) @map("_id") @db.ObjectId
    firstName              String
    lastName               String
    email                  String            @unique
    password               String?
    photo                  String?
    reviews                MovieReview[]
    likes                  MovieReviewLike[]
    watchList              MovieWatchList[]
    activities             Activity[]
    friends                User[]            @relation(fields: [friendsIds], references: [id], name: "friends")
    friendsIds             String[]          @db.ObjectId
    friendOf               User[]            @relation(fields: [friendOfIds], references: [id], name: "friends")
    friendOfIds            String[]          @db.ObjectId
    sentFriendRequests     FriendRequest[]   @relation("sentUser")
    receivedFriendRequests FriendRequest[]   @relation("receivedUser")
    sentMessages           Message[]         @relation("sender")
    receivedMessages       Message[]         @relation("recipient")
    movieRecommendations   MovieRecommendationCache[] @relation("movieRecommendationUser")
    friendRecommendations  FriendRecommendationCache[] @relation("friendRecommendationUser")
    recommendedToUsers     FriendRecommendationCache[] @relation("recommendedUser")
}

model Movie {
    id              String           @id @default(auto()) @map("_id") @db.ObjectId
    title           String
    releaseYear     Int
    director        String
    overview        String
    language        String
    genres          String[]
    cast            String[]         @default([])
    keywords        String[]         @default([])
    runtime         Int
    popularity      Float            @default(0)
    reviews         MovieReview[]
    avgRating       Float
    numRatings      Int
    poster          String
    onWatchList     MovieWatchList[]
    userActivities  Activity[]
    recommendations MovieRecommendationCache[]
}

model MovieRecommendationCache {
    id                 String   @id @default(auto()) @map("_id") @db.ObjectId
    user               User     @relation(fields: [userId], references: [id], name: "movieRecommendationUser")
    userId             String   @db.ObjectId
    movie              Movie    @relation(fields: [movieId], references: [id])
    movieId            String   @db.ObjectId
    score              Float
    recommendedByCount Int
    generatedAt        DateTime

    @@unique([userId, movieId])
    @@index([userId, score])
}

model FriendRecommendationCache {
    id                   String   @id @default(auto()) @map("_id") @db.ObjectId
    user                 User     @relation(fields: [userId], references: [id], name: "friendRecommendationUser")
    userId               String   @db.ObjectId
    recommendedUser      User     @relation(fields: [recommendedUserId], references: [id], name: "recommendedUser")
    recommendedUserId    String   @db.ObjectId
    similarityScore      Float
    sharedMovieCount     Int
    sharedFavoriteTitles String[]
    generatedAt          DateTime

    @@unique([userId, recommendedUserId])
    @@index([userId, similarityScore])
}

model MovieReview {
    id             String            @id @default(auto()) @map("_id") @db.ObjectId
    movie          Movie             @relation(fields: [movieId], references: [id])
    movieId        String            @db.ObjectId
    user           User              @relation(fields: [userId], references: [id])
    userId         String            @db.ObjectId
    date           DateTime
    rating         Int
    text           String?
    likeCount      Int               @default(0)
    likedBy        MovieReviewLike[]
    userActivities Activity[]

    @@unique([movieId, userId])
    @@index([userId])
    @@index([movieId, likeCount])
}

model MovieReviewLike {
    id       String      @id @default(auto()) @map("_id") @db.ObjectId
    review   MovieReview @relation(fields: [reviewId], references: [id])
    reviewId String      @db.ObjectId
    user     User        @relation(fields: [userId], references: [id])
    userId   String      @db.ObjectId

    @@unique([reviewId, userId])
}

model MovieWatchList {
    id      String @id @default(auto()) @map("_id") @db.ObjectId
    user    User   @relation(fields: [userId], references: [id])
    userId  String @db.ObjectId
    movie   Movie  @relation(fields: [movieId], references: [id])
    movieId String @db.ObjectId

    @@unique([movieId, userId])
}

model Activity {
    id            String       @id @default(auto()) @map("_id") @db.ObjectId
    user          User         @relation(fields: [userId], references: [id])
    userId        String       @db.ObjectId
    action        String
    reviewRating  Int?
    reviewText    String?
    movie         Movie?       @relation(fields: [movieId], references: [id])
    movieId       String?      @db.ObjectId
    movieReview   MovieReview? @relation(fields: [movieReviewId], references: [id])
    movieReviewId String?      @db.ObjectId
    date          DateTime
}

model FriendRequest {
    id             String @id @default(auto()) @map("_id") @db.ObjectId
    sentUser       User   @relation(fields: [sentUserId], references: [id], name: "sentUser")
    sentUserId     String @db.ObjectId
    receivedUser   User   @relation(fields: [receivedUserId], references: [id], name: "receivedUser")
    receivedUserId String @db.ObjectId

    @@unique([sentUserId, receivedUserId])
}

model Message {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    sender      User     @relation(fields: [senderId], references: [id], name: "sender")
    senderId    String   @db.ObjectId
    recipient   User     @relation(fields: [recipientId], references: [id], name: "recipient")
    recipientId String   @db.ObjectId
    text        String
    date        DateTime
    wasRead     Boolean
}
